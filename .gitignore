# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/master/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/

# Never ignore Asset meta data
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
[Aa]ssets/Plugins/Editor/JetBrains*

# Gradle cache directory
.gradle/

# vscode cache directory
.vscode/

# MSYS2/Git Bash crash dump
*.stackdump

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db
#*.mdb

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
#*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.apks
*.aab

# Crashlytics generated file
crashlytics-build.properties

# 前导斜杠锚定仓库根，避免 AssetBundles/ 误伤 Assets/Framework/Docs/Editor/Tools/AssetBundles/ 文档
/AssetBundles/
Bundles/
Assets/GeneratedLocalRepo/
Assets/GeneratedLocalRepo.meta
Assets/HybridCLRGenerate/
Assets/HybridCLRGenerate.meta

# 构建产物（首包资源每次 Build 重生成，不入库）
Assets/StreamingAssets/
Assets/StreamingAssets.meta

# YooAsset 编辑器沙盒缓存（等同真机 persistentDataPath/yooasset）
/yooasset/

# Unity Performance Testing 构建期临时配置（Build 结束自动清理，异常中断会残留）
PerformanceTestRunInfo.json
PerformanceTestRunInfo.json.meta
PerformanceTestRunSettings.json
PerformanceTestRunSettings.json.meta

out/

*BackUpThisFolder_ButDontShipItWithYourGame

*.log

UserSettings/

com.Tivadar.Best.HTTP.xml
com.Tivadar.Best.TLSSecurity.xml

HybridCLRData/*
.claude/settings.local.json

*.idea
*.utmp

# Python 字节码缓存
__pycache__/
*.pyc

# Luban auto-generated config directories（各 Demo Excels 副本内的产物，跟人不跟版本）
Assets/Samples/*/Excels/**/_configs/
Assets/Samples/*/Excels/**/_configs.meta
Assets/Samples/*/Excels/**/_luban_temp_*/
# 项目根 Docs/（设计/计划文档 + Android 签名凭据，跟人不跟版本，禁入 git）
# 前导斜杠锚定仓库根，避免误伤 Assets/Framework/Docs/
/Docs/

# TMP 导入资源（由 TMP Essentials 一键再生，跟人不跟版本）
Assets/TextMesh Pro/
Assets/TextMesh Pro.meta

# AppLovin MAX SDK（第三方导入，跟人不跟版本，与 EDM/Plugins 同例）
Assets/MaxSdk/
Assets/MaxSdk.meta

# 开源脱敏凭据备份（本地专用，含真实密钥/域名，禁入 git）
/Assets/Samples/_credentials-backup.local.md
/Assets/Samples/_credentials-backup.local.md.meta

# Personal Claude config
.claude/CLAUDE.local.md

# Obsidian Vault 本地状态（含工作区/缓存/插件，跟人不跟版本）
Assets/Framework/Minds/.obsidian/

ProjectSettings/AndroidResolverDependencies.xml

# Demo 编译产物（HybridCLR AOT/HotUpdate），各 Demo 由 Editor 工具按需重生成，全部不入库
/[Aa]ssets/[Ss]amples/*/[Dd]lls/
/[Aa]ssets/[Ss]amples/*/[Dd]lls.meta

# Assets/Plugins（根）仅存放自动生成内容：Unity 模板选项勾选 / EDM resolve 刷新的 gradle 模板与
# proguard、unity-mcp 生成的 Roslyn 库、Firebase 构建产物等，均无需人为维护，整目录不入库。
# 注：仅匹配根 Assets/Plugins/，不影响 Assets/Samples/**/Plugins 与 UPMPackages/**/Plugins。
# 与 Assets/StreamingAssets / Resources / GeneratedLocalRepo 同例，连同文件夹元数据一并忽略
# （全自动生成目录，保留 .meta 在干净 clone 上会变孤儿 meta 被 Unity 删除，制造无谓 diff）。
/[Aa]ssets/[Pp]lugins/
/[Aa]ssets/[Pp]lugins.meta

# Assets/Tests：测试套件只在主/内部仓维护运行，公开框架仓不随带测试源码，整目录不入库。
/[Aa]ssets/[Tt]ests/
/[Aa]ssets/[Tt]ests.meta

# 第三方工具：SQLiteStudio 为 GPLv3 GUI 二进制（缺失时由 EditorUtil.FileSystem.OpenSQLiteStudio
# 弹下载引导，无需随仓携带），不入库。
/Tools/SQLiteStudio/

# AppLovin 集成设置（含具体游戏的同意流/隐私政策配置，由 AppLovin Integration Manager 按工程重新生成）
ProjectSettings/AppLovinInternalSettings.json

# Samples~ 处理（两部分）：
# 1) 屏蔽发版临时态 Samples~（publish 期间从 Assets/Samples 复制创建，Stage3 清理，异常残留禁入库）
/[Aa]ssets/[Ff]ramework/[Ss]amples~/
/[Aa]ssets/[Ff]ramework/[Ss]amples~.dev/
/[Aa]ssets/[Ff]ramework/[Ss]amples~.dev.meta
/[Aa]ssets/[Ff]ramework/[Ss]amples~.meta
/UPMPackages/*/[Ss]amples~/
/UPMPackages/*/[Ss]amples~/**
/UPMPackages/*/[Ss]amples~.dev/
/UPMPackages/*/[Ss]amples~.dev/**
/UPMPackages/*/[Ss]amples~.meta
/UPMPackages/*/[Ss]amples~.dev.meta
# 2) 放行 vendored 上游包的可导入样例 Core/Samples~（覆盖全局 ~/.gitignore_global 的 *~，使其可正常追踪）
# 锚定到 UPMPackages/*/Core/，不用 **，避免通配遍历误伤同包的临时态 Samples~
!/UPMPackages/*/[Cc]ore/[Ss]amples~/

# 多 coder 并行隔离用的 git worktree 目录（superpowers:using-git-worktrees）
.worktrees/
.claude/worktrees/

# macOS Finder 元数据，禁入 git
.DS_Store
**/.DS_Store

Assets/Resources/
Assets/Resources.meta

.codegraph


# PlugPals registry 地址：per-project 本地配置，跟人不跟版本
# （内网地址外网不可达、无需脱敏；默认值由 EditorUtil.PlugPals.Registries 代码常量回退，缺该文件也能用）
ProjectSettings/Nova/PlugPalsRegistries.json

# EDM（Google Version Handler）工程设置：构建期由 EDM 自动重生成，含 analytics cookie，跟人不跟版本
ProjectSettings/GvhProjectSettings.xml

# Nova 工作区激活 ConfigMaster 锚点：跟人不跟版本（编辑器按当前 sample/scene 自动重建）
ProjectSettings/Nova/Globals.json

# AI / IDE 工具配置与脚手架：研发侧专用，不进公开仓
/.agents/
/.cursor/
/.claude/
/.mcp.json
/.claudeignore
/.nova/
# 散落各目录的 AI 路由文档 AGENTS.md（任意位置）及其 Unity meta
AGENTS.md
AGENTS.md.meta

# Firebase 桌面（Editor beta）核心原生库：单文件超 GitHub 100MB 限制，且 Firebase 官方定位「仅开发期、不用于发布」；
# 不随开源仓分发，缺失时由 FirebaseDesktopLibraryGuard 引导从官方 SDK 补齐（真机 Android/iOS 构建不依赖）
/UPMPackages/com.solotopia.nova.framework.sdk.firebase/Firebase/Plugins/x86_64/FirebaseCppApp-*.bundle
/UPMPackages/com.solotopia.nova.framework.sdk.firebase/Firebase/Plugins/x86_64/FirebaseCppApp-*.bundle.meta
/UPMPackages/com.solotopia.nova.framework.sdk.firebase/Firebase/Plugins/x86_64/FirebaseCppApp-*.so
/UPMPackages/com.solotopia.nova.framework.sdk.firebase/Firebase/Plugins/x86_64/FirebaseCppApp-*.so.meta
/UPMPackages/com.solotopia.nova.framework.sdk.firebase/Firebase/Plugins/x86_64/FirebaseCppApp-*.dll
/UPMPackages/com.solotopia.nova.framework.sdk.firebase/Firebase/Plugins/x86_64/FirebaseCppApp-*.dll.meta
